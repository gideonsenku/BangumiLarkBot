# 飞书自建应用 https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 传输模式：websocket (推荐，无需公网) 或 webhook
FEISHU_TRANSPORT=websocket
# 机器人自身 open_id（可选，用于群聊 @ 检测）
FEISHU_BOT_OPEN_ID=

# Bangumi App https://bgm.tv/dev/app/create
BGM_APP_ID=bgm123456
BGM_APP_SECRET=123dsda123456
# 可选：长期 access_token (无绑定场景使用) https://next.bgm.tv/demo/access-token
BGM_ACCESS_TOKEN=

# 本地 API Server (OAuth 回调 + 健康检查 + /push)
API_PORT=6008
# 必须为 HTTPS 公网地址，用于 Bangumi OAuth 回调
API_WEBSITE_BASE=https://oauth.example.com:6008
# 推送接口鉴权头
API_AUTH_KEY=changeme-strong-random-key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_SESSION_EXPIRES=86400

# 日志等级：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
